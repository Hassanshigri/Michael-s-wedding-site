# Server Configuration
PORT=3000
NODE_ENV=development

# For local development, use one of these options:

# Option 1: Local PostgreSQL (if installed)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wedding_dev

# Option 2: SQLite (uncomment for local SQLite development)
DATABASE_URL=sqlite:./database.sqlite

# Option 3: Remote Render PostgreSQL (uncomment when deploying to production)
# DATABASE_URL=postgresql://wedding_db_npgr_user:H05NoPun4ffHkg6CRry4Q76hfsNJBYbm@dpg-d6k5selm5p6s7388q6cg-a.singapore-postgres.render.com/wedding_db_npgr

# Individual database fields (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wedding_dev
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Secret (generate a random string)
JWT_SECRET=your_super_secret_random_string_here_change_this

# Admin Credentials
ADMIN_USERNAME=admin
# Generate this with: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"
ADMIN_PASSWORD_HASH=$2a$10$...

# Email Configuration (for RSVP confirmations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password